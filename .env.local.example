# Supabase (REQUIRED)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (REQUIRED for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Cron secret (REQUIRED for the daily phrase notification)
# Set the same value in Vercel env vars; Vercel Cron sends it automatically
# as "Authorization: Bearer <CRON_SECRET>" to /api/cron/daily-phrase.
CRON_SECRET=

# Stripe (REQUIRED for payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Cloudflare Stream (OPTIONAL - for video uploads)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_STREAM_SIGNING_KEY=
CLOUDFLARE_STREAM_KEY_ID=

# Groq (REQUIRED for AI assistant - get free key at console.groq.com)
# Free tier: 14,400 req/day, 30 req/min — much more reliable than OpenRouter free models.
GROQ_API_KEY=gsk_...
# Optional: pin a specific Groq model. Leave empty to use the automatic fallback list.
# Options: llama-3.3-70b-versatile | deepseek-r1-distill-llama-70b | gemma2-9b-it | llama-3.1-8b-instant
GROQ_MODEL=

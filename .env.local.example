# Supabase (REQUIRED)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (REQUIRED for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Stripe (REQUIRED for payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Cloudflare Stream (OPTIONAL - for video uploads)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_STREAM_SIGNING_KEY=
CLOUDFLARE_STREAM_KEY_ID=

# OpenRouter (REQUIRED for AI assistant - get free key at openrouter.ai)
OPENROUTER_API_KEY=sk-o
# Free model by default. Change to e.g. "anthropic/claude-3.5-sonnet" for premium.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

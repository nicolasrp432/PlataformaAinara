{
  "name": "plataforma-ainara",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate:local": "wrangler d1 migrations apply leader-blueprint-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply leader-blueprint-db",
    "db:seed:local": "wrangler d1 execute leader-blueprint-db --local --file=./migrations/0002_seed_data.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed:local"
  },
  "dependencies": {
    "next": "^15.3.2",
